// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id             Int        @id @default(autoincrement())
  slug           String     @unique
  name           String
  colorHex       String
  emoji          String     @default("🏴")
  isHidden       Boolean    @default(false)
  power          Int        @default(10)
  createdAt      DateTime   @default(now())
  users          User[]
  claims           Claim[]
  ownedLocations   Location[]        @relation("OwnedLocations")
}

model User {
  id        Int      @id @default(autoincrement())
  handle    String   @unique
  firstName String?
  lastName  String?
  email     String?
  age       Int?
  isApproved Boolean @default(false)
  avatarType String  @default("sprite")
  avatarSprite String @default("adventurer")
  avatarSeed String?
  avatarPhotoDataUrl String?
  passwordHash String?
  power     Float    @default(30)
  money     Float    @default(30)
  population Float   @default(0)
  lastDailyClaimAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teamId    Int
  team      Team     @relation(fields: [teamId], references: [id])
  claims    Claim[]
  locationGreetings LocationGreeting[]
  revengeDiscounts RevengeDiscount[]
  sentTradeOffers     TradeOffer[] @relation("SentTradeOffers")
  receivedTradeOffers TradeOffer[] @relation("ReceivedTradeOffers")
}

model Location {
  id               Int       @id @default(autoincrement())
  slug             String    @unique
  qrCode           String    @unique
  name             String
  type             String    @default("camp")
  armor            Int       @default(8)
  area             Int       @default(1000)
  currentPopulation Float    @default(1)
  popToMoney       Int       @default(0)
  popToPower       Int       @default(0)
  popToPopulation  Int       @default(30)
  workersUpdatedAt DateTime  @default(now())
  workersAutoStoppedAt DateTime?
  economyUpdatedAt DateTime  @default(now())
  image            String    @default("⛺")
  summary          String
  content          String
  latitude         Float
  longitude        Float
  claimRadiusM     Int       @default(50)
  neighbors        String?
  territoryGeoJson String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  ownerTeamId      Int?
  lastClaimedAt    DateTime?
  ownerTeam        Team?     @relation("OwnedLocations", fields: [ownerTeamId], references: [id])
  claims           Claim[]
  greetings        LocationGreeting[]
  builtBuildings   BuiltBuilding[]
  revengeDiscounts RevengeDiscount[]
}

model Claim {
  id          Int      @id @default(autoincrement())
  message     String?
  latitude    Float
  longitude   Float
  accuracyM   Float?
  distanceM   Float
  createdAt   DateTime @default(now())
  locationId  Int
  teamId      Int
  userId      Int
  location    Location @relation(fields: [locationId], references: [id])
  team        Team     @relation(fields: [teamId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([locationId, createdAt])
  @@index([teamId, createdAt])
  @@index([userId, createdAt])
}

model LocationGreeting {
  id         Int      @id @default(autoincrement())
  latitude   Float
  longitude  Float
  accuracyM  Float?
  distanceM  Float
  createdAt  DateTime @default(now())
  locationId Int
  userId     Int
  location   Location @relation(fields: [locationId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([locationId, createdAt])
  @@index([userId, createdAt])
}

model AdminSettings {
  id             Int   @id @default(1)
  passwordHash   String
  moneyRate      Float @default(0.5)
  powerRate      Float @default(0.5)
  populationRate Float @default(1)
  claimPopulationLossPercent Float @default(25)
  claimPopulationMin Int @default(3)
  productionTimeoutHours Float @default(24)
  dailyLoginReward Float @default(8)
  revengeDiscountHours Float @default(8)
  encourageCost Float @default(10)
  encourageArmorBonus Float @default(5)
}

model BuildingDef {
  id           Int             @id @default(autoincrement())
  name         String          @unique
  svgKey       String
  locationType String
  cost         Float
  effectGpop   Float           @default(0)
  effectPow    Float           @default(0)
  effectMaxpop Float           @default(0)
  effectMny    Float           @default(0)
  effectArm    Float           @default(0)
  instances    BuiltBuilding[]
}

model BuiltBuilding {
  id            Int         @id @default(autoincrement())
  locationId    Int
  buildingDefId Int
  createdAt     DateTime    @default(now())
  location      Location    @relation(fields: [locationId], references: [id])
  buildingDef   BuildingDef @relation(fields: [buildingDefId], references: [id])

  @@unique([locationId, buildingDefId])
}

model RevengeDiscount {
  id         Int      @id @default(autoincrement())
  locationId Int
  userId     Int
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  location   Location @relation(fields: [locationId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([locationId, userId])
  @@index([userId, expiresAt])
}

enum TradeResourceType {
  MONEY
  POWER
}

enum TradeOfferStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

model TradeOffer {
  id              Int               @id @default(autoincrement())
  fromUserId      Int
  toUserId        Int
  offerType       TradeResourceType
  offerAmount     Float
  requestType     TradeResourceType
  requestAmount   Float             @default(0)
  status          TradeOfferStatus  @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  acceptedAt      DateTime?
  cancelledAt     DateTime?
  fromUser        User              @relation("SentTradeOffers", fields: [fromUserId], references: [id])
  toUser          User              @relation("ReceivedTradeOffers", fields: [toUserId], references: [id])

  @@index([fromUserId, createdAt])
  @@index([toUserId, createdAt])
  @@index([status, createdAt])
}
